NODE_ENV=test

# Suppress KafkaJS v2 partitioner warning
KAFKAJS_NO_PARTITIONER_WARNING=1

# Kafka — docker-compose.test.yml (apache/kafka KRaft)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=email-service-test
KAFKA_CONSUMER_GROUP=email-service-group-test

# SMTP — smtp4dev container (porta 25, web UI em http://localhost:5000)
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Email Service Test <no-reply@test.example.com>"
MAIL_IGNORE_TLS=true
