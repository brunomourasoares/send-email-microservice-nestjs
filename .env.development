NODE_ENV=development

# Suppress KafkaJS v2 partitioner warning
KAFKAJS_NO_PARTITIONER_WARNING=1

# Kafka — docker-compose.dev.yml (apache/kafka KRaft, porta externa 9092)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=email-service-dev
KAFKA_CONSUMER_GROUP=email-service-group-dev

# SMTP — smtp4dev container (porta 25, web UI em http://localhost:5000)
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Email Service Dev <no-reply@dev.example.com>"
MAIL_IGNORE_TLS=true
