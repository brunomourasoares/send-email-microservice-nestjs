NODE_ENV=development

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=email-service-dev
KAFKA_CONSUMER_GROUP=email-service-group-dev

# SMTP / Mail — smtp4dev local (container)
# Interface web: http://localhost:5000
MAIL_HOST=localhost
MAIL_PORT=25
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Email Service Dev <no-reply@dev.example.com>"
MAIL_IGNORE_TLS=true
