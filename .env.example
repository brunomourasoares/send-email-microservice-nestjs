# Profile — development | test | production
NODE_ENV=development

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=email-service
KAFKA_CONSUMER_GROUP=email-service-group

# SMTP / Mail
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your-smtp-user
MAIL_PASS=your-smtp-password
MAIL_FROM="Email Service <no-reply@example.com>"
# Set to true only for local SMTP servers without TLS (e.g. smtp4dev on port 25)
MAIL_IGNORE_TLS=false
